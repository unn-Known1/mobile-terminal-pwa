{
  "name": "mobile-terminal-pwa",
  "version": "2.0.0",
  "type": "module",
  "description": "Mobile Terminal PWA - Full-featured terminal accessible from mobile browsers",
  "author": "Mobile Terminal",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/server.js",
    "client": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "build:win": "npm run build && electron-builder --win",
    "build:linux": "npm run build && electron-builder --linux",
    "build:all": "npm run build && electron-builder --win --linux",
    "build:deb": "npm run build && electron-builder --linux deb",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.mobile-terminal.pwa",
    "productName": "Mobile Terminal",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "server/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mobile Terminal"
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "category": "Utility",
      "icon": "build/icons"
    },
    "deb": {
      "depends": ["libx11-6", "libxext6", "libxss1", "libglib2.0-0", "libnss3", "libasound2"],
      "section": "utils"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.utilities"
    }
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "cookie-parser": "^1.4.7",
    "express": "^4.18.2",
    "lucide-react": "^0.383.0",
    "multer": "^2.1.1",
    "node-pty": "^1.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-search": "^0.13.0",
    "xterm-addon-web-links": "^0.9.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.0.0"
  }
}
