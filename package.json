{
  "name": "mobile-terminal-pwa",
  "version": "2.0.0",
  "type": "module",
  "description": "Mobile Terminal PWA - Full-featured terminal accessible from mobile browsers",
  "author": "Mobile Terminal",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/server.js",
    "client": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "build:win": "npm run build && electron-builder --win",
    "build:linux": "npm run build && electron-builder --linux",
    "build:mac": "npm run build && electron-builder --mac",
    "build:all": "npm run build && electron-builder --win --linux",
    "build:deb": "npm run build && electron-builder --linux deb"
  },
  "build": {
    "appId": "com.mobile-terminal.pwa",
    "productName": "Mobile Terminal",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "server/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mobile Terminal"
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "icon": "build/icons",
      "maintainer": "Mobile Terminal <dev@mobileterminal.com>"
    },
    "deb": {
      "depends": [
        "libx11-6",
        "libxext6",
        "libxss1",
        "libglib2.0-0",
        "libnss3",
        "libasound2"
      ],
      "packageCategory": "utils"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.utilities"
    }
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "archiver": "^7.0.1",
    "cookie-parser": "^1.4.7",
    "express": "^4.18.2",
    "lucide-react": "^0.383.0",
    "multer": "^2.1.1",
    "node-pty": "^1.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-web-links": "^0.11.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^40.0.0",
    "@electron/rebuild": "^3.7.1",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.0"
  },
  "overrides": {
    "tar": "^7.4.0",
    "dompurify": "^3.2.4",
    "@tootallnate/once": "^3.0.1",
    "http-proxy-agent": "^5.0.0",
    "node-gyp": "^11.0.0",
    "make-fetch-happen": "^14.0.0"
  }
}
